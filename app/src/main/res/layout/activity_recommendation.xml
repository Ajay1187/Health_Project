<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_health_theme">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_reco_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:background="@drawable/txt_back"
            android:padding="10dp"
            android:textStyle="bold"
            android:textSize="24sp"
            android:textColor="#B2DFDB"
            android:layout_marginBottom="14dp" />

        <TextView
            android:id="@+id/tv_reco_disease_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#C8E6C9"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tv_reco_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E3F2FD"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tv_reco_precautions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E3F2FD"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tv_reco_doctor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E3F2FD"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tv_reco_diet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E3F2FD"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tv_reco_exercise"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E3F2FD" />

    </LinearLayout>
</ScrollView>
