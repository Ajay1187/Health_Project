<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/background_1img"
    android:padding="10dp">

    <EditText
        android:id="@+id/txt_doctor_id"
        style="@style/AppFontStyle"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/blur_bg"
        android:enabled="false"
        android:gravity="center"
        android:hint="Doctor ID"
        android:textColor="@android:color/white"
        android:textColorHint="@android:color/white" />

    <EditText
        android:id="@+id/txt_patient_medical_id"
        style="@style/AppFontStyle"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/blur_bg"
        android:gravity="center"
        android:hint="Enter Patient Medical ID"
        android:inputType="text"
        android:textColor="@android:color/white"
        android:textColorHint="@android:color/white" />

    <EditText
        android:id="@+id/txt_doctor_date"
        style="@style/AppFontStyle"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/blur_bg"
        android:enabled="false"
        android:gravity="center"
        android:hint="Date"
        android:textColor="@android:color/white"
        android:textColorHint="@android:color/white" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Select Disease"
        android:textColor="@android:color/white"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/spn_doctor_disease"
        style="@style/AppFontStyle"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/blur_bg" />

    <Button
        android:id="@+id/btn_doctor_add_issue"
        style="@style/AppFontStyle"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="20dp"
        android:background="@drawable/blur_bg"
        android:text="Add Health Issue"
        android:textSize="20dp"
        android:textStyle="bold" />

</LinearLayout>
